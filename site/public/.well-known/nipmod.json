{
  "formatVersion": 1,
  "type": "dev.nipmod.discovery.v1",
  "name": "Nipmod",
  "description": "The package layer for AI agents.",
  "homepage": "https://nipmod.com",
  "previewImage": "https://nipmod.com/nipmod-logo.png",
  "trustPage": "https://nipmod.com/trust",
  "api": {
    "baseUrl": "https://nipmod.com",
    "description": "Hosted package discovery, trust checks and safe install plans for agents.",
    "openapi": "https://nipmod.com/api/openapi",
    "search": "https://nipmod.com/api/search",
    "resolve": "https://nipmod.com/api/resolve",
    "inspect": "https://nipmod.com/api/inspect",
    "installPlan": "https://nipmod.com/api/install-plan",
    "sourceHealth": "https://nipmod.com/api/sources/health",
    "betaKey": "https://nipmod.com/api/keys/beta",
    "mcp": "https://nipmod.com/api/mcp",
    "access": {
      "publicBeta": false,
      "keyRequired": true,
      "rateLimited": true,
      "selfServiceBetaKey": "https://nipmod.com/api/keys/beta",
      "requiredHeaders": [
        "x-nipmod-api-key",
        "Authorization: Bearer <key>"
      ],
      "keyStatus": "Package intelligence API calls require a key. Free beta keys can be issued by POST /api/keys/beta and are verified against server-side hashes.",
      "usageLogging": "Usage events store route, status, source, result count, duration and hashed identifiers. They do not store raw API keys, raw IP addresses, raw queries, package names or user-agent fingerprints."
    },
    "trustPolicy": {
      "version": "external-v2",
      "summary": "External scores combine source metadata, package health signals, public usage context, warnings and install-plan risk. A score is review context, not permission to execute code."
    },
    "selectionPolicy": {
      "version": "agent-selection-v1",
      "summary": "Search responses include a recommended candidate, gate state and rank breakdown for agent planning."
    },
    "writeBoundary": "Hosted API calls do not write to a caller workspace.",
    "localDeepScan": {
      "command": "nipmod deep-scan <path> --json",
      "mode": "local-static",
      "hostedApiRunsDeepScan": false,
      "notes": "Deep scan reads files and supported package artifacts already present locally. The hosted API does not clone repositories, extract artifacts, install packages or execute code."
    }
  },
  "sources": [
    "npm",
    "pypi",
    "github",
    "huggingface-model",
    "huggingface-dataset",
    "mcp"
  ],
  "archive": {
    "prepare": "https://nipmod.com/api/archive/prepare",
    "search": "https://nipmod.com/api/archive/search",
    "confirm": "https://nipmod.com/api/archive/confirm",
    "status": "https://nipmod.com/api/archive/status",
    "receiptType": "dev.nipmod.package-intelligence-receipt.v1",
    "prepareStores": false,
    "confirmStores": "requires authorized server writer",
    "seed": {
      "status": "operator-controlled",
      "description": "Seed v1 confirms a small set of external_indexed package intelligence records across npm, PyPI, GitHub, Hugging Face and MCP after source re-inspection.",
      "bulkMirror": false,
      "verifiedClaim": false
    },
    "rejects": [
      "trust.decision avoid",
      "trust.decision unknown",
      "trust.risk high",
      "trust.risk unknown",
      "below threshold trust score",
      "high risk install commands"
    ],
    "writeBoundary": "Prepared records are not persisted by /api/archive/prepare. Durable writes require archive confirmation and an authorized server writer."
  },

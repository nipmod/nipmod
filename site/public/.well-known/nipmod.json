  "agent": {
    "llms": "https://nipmod.com/llms.txt",
    "prompts": "https://nipmod.com/agent-prompts.json",
    "runbook": "https://nipmod.com/api-access",
    "workflow": [
      "install",
      "verifyInstaller",
      "setupPublish",
      "doctor",
      "search",
      "externalResolve",
      "externalInspect",

FROM node:22-bookworm-slim

RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY tools ./tools

ENV NODE_ENV=production
ENV PORT=8080
ENV NIPMOD_SCOUT_INTERVAL_MS=300000

EXPOSE 8080

CMD ["node", "tools/scout-server.mjs"]

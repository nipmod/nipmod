.DS_Store

# Dependencies and build output
node_modules/
dist/
.next/
.next.stale.*/
out/
target/

# Local service state and generated helpers
.gitlawb-bin/
.nipmod/*
.playwright-mcp/
gitlawb-node/
probe-work/
site/.vercel/
site/tsconfig.tsbuildinfo
tsconfig.tsbuildinfo
tools/tsconfig.tsbuildinfo

# Local filesystem conflict copies of generated registry package docs
site/public/registry/packages/* [0-9].json

# Local planning artifacts
.claude/
CLAUDE.md
site/CLAUDE.md
findings.md
mass-readiness-plan.md
nipmod-*-snapshot.md
nipmod-master-spec.md
nipmod-gitlawb-probe-report.md
progress.md
task_plan.md
*.png
!site/public/claude-logo.png
!site/public/codex-logo.png
!site/public/hermes-logo.png
!site/public/architecture.png
!site/public/benchmark-agent-preflight.png
!site/public/benchmark-cover-simple.png
!site/public/benchmark-thread/*.png
!site/public/agents/*.png

# Release tarballs are shipped through GitHub Releases. Keep only small
# checksum and detached-signature sidecars in the source repository.
site/public/releases/*.tgz
!site/public/releases/*.tgz.sha256
!site/public/releases/*.tgz.sig
site/public/releases/nipmod-* [0-9].tgz*


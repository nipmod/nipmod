  },
  "claims": {
    "index": "https://nipmod.com/claims/index.json",
    "candidatePage": "https://nipmod.com/candidates",
    "verifyCommand": "nipmod claim verify gitlawb://did:key:.../repo --json",
    "indexCommand": "nipmod claim index --node https://node.nipmod.com --json"
  },
  "scout": {
    "health": "https://nipmod.com/scout/health",
    "last": "https://nipmod.com/scout/last",
    "candidates": "https://nipmod.com/scout/candidates",

{
  "name": "nipmod",
  "version": "1.2.1",
  "private": true,
  "packageManager": "pnpm@10.30.0",
  "type": "module",
  "bin": {
    "nipmod": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "security:deps": "pnpm audit --audit-level high",
    "test": "vitest run --testTimeout 20000",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "cli": "tsx src/cli.ts"
  },
  "dependencies": {
    "@scure/base": "^2.2.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "esbuild": "^0.28.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}

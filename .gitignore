.DS_Store

# Dependencies and build output
node_modules/
dist/
.next/
.next.stale.*/
out/
target/

# Local service state and generated helpers
.gitlawb-bin/
.nipmod/
.playwright-mcp/
gitlawb-node/
probe-work/
site/.vercel/
site/tsconfig.tsbuildinfo

# Local filesystem conflict copies of generated registry package docs
site/public/registry/packages/* [0-9].json

# Local planning artifacts
findings.md
mass-readiness-plan.md
nipmod-*-snapshot.md
nipmod-master-spec.md
nipmod-gitlawb-probe-report.md
progress.md
task_plan.md
*.png

# Keep only current public release artifact in git.
# The release builder fails if a new release artifact is still ignored.
site/public/releases/*

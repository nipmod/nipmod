    "commands": {
      "install": "curl https://nipmod.com/i|bash",
      "verifyInstaller": "curl -fLO https://nipmod.com/install.sh\ncurl -fLO https://nipmod.com/install.sh.sha256\nshasum -a 256 -c install.sh.sha256\nbash install.sh",
      "setupPublish": "nipmod setup gitlawb",
      "doctor": "nipmod doctor --online",
      "search": "nipmod search <query> --online",
      "externalResolve": "GET https://nipmod.com/api/resolve?q=<query>&sources=npm,pypi,github,huggingface-model,huggingface-dataset,mcp",
      "externalSearch": "GET https://nipmod.com/api/search?q=<query>&sources=npm,pypi,github,huggingface-model,huggingface-dataset,mcp",
      "externalInspect": "GET https://nipmod.com/api/inspect?source=npm&name=<package-name>",
      "externalInstallPlan": "GET https://nipmod.com/api/install-plan?source=npm&name=<package-name>",
      "packageIntelligencePrepare": "GET https://nipmod.com/api/archive/prepare?source=npm&name=<package-name>",
      "packageIntelligenceSearch": "GET https://nipmod.com/api/archive/search?q=<query>",
      "packageIntelligenceConfirmDryRun": "POST https://nipmod.com/api/archive/confirm {\"source\":\"npm\",\"name\":\"<package-name>\",\"dryRun\":true}",
      "packageIntelligenceStatus": "GET https://nipmod.com/api/archive/status",
      "sourceHealth": "GET https://nipmod.com/api/sources/health",
      "inspect": "nipmod inspect <package-specifier> --json",
      "view": "nipmod view <package-name> --json",
      "installPlan": "nipmod install --plan <package-specifier> --json",
      "mcpResolve": "{\"jsonrpc\":\"2.0\",\"id\":3,\"method\":\"tools/call\",\"params\":{\"name\":\"nipmod.resolve\",\"arguments\":{\"query\":\"telegram bot\",\"sources\":[\"npm\",\"pypi\",\"github\",\"huggingface-model\",\"mcp\"]}}}",
      "mcpExternalInstallPlan": "{\"jsonrpc\":\"2.0\",\"id\":4,\"method\":\"tools/call\",\"params\":{\"name\":\"nipmod.external_install_plan\",\"arguments\":{\"source\":\"npm\",\"name\":\"node-telegram-bot-api\"}}}",
      "mcpDemo": "{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"tools/call\",\"params\":{\"name\":\"nipmod.demo\",\"arguments\":{\"host\":\"Codex\",\"package\":\"<package-specifier>\"}}}",
      "mcpControlledInstall": "{\"jsonrpc\":\"2.0\",\"id\":2,\"method\":\"tools/call\",\"params\":{\"name\":\"nipmod.install\",\"arguments\":{\"specifier\":\"<package-specifier>\",\"confirmInstall\":\"write-lockfile\"}}}",
      "installPackage": "nipmod install <package-specifier>",
      "addPackage": "nipmod add <package-specifier> --online",
      "audit": "nipmod audit --online",
      "sbom": "nipmod sbom --json",
      "publishDryRun": "nipmod publish . --dry-run --json",
      "claimVerify": "nipmod claim verify gitlawb://did:key:.../repo --json",
      "claimIndex": "nipmod claim index --node https://node.nipmod.com --json"
    }
  },
